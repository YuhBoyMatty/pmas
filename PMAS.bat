:: =============================================================================
:: PMAS_v12.bat - Başlatıcı / Launcher
:: =============================================================================
::
:: [TÜRKÇE]
:: Bu dosya, asıl aktivasyon uygulamasını (PMAS.bat) doğrudan çalıştırmak
:: yerine geçici bir klasöre çıkararak çalıştırır.
::
:: Tercih edilme sebebi:
::   Windows Defender, aktivasyon uygulamasındaki bazı işlemleri zararlı
::   yazılım olarak algılayıp engelleyebilmektedir. Bu başlatıcı dosyası;
::   - Çalıştırmadan önce %TEMP% klasöründeki pmas_*.bat dosyasını otomatik
::     Windows Defender dışlamasına ekler,
::   - Asıl uygulamayı rastgele isimli geçici bir dosyaya çıkarıp çalıştırır,
::   - İşlem tamamlandığında dışlamayı kaldırır ve geçici dosyayı siler.
::------------------------------------------------------------------------------
:: 
:: [ENGLISH]
:: This file extracts and runs the main activation application (PMAS.bat)
:: from a temporary folder instead of running it directly.
::
:: Reason for this approach:
::   Windows Defender may detect and block certain operations in the activation
::   application. This launcher file:
::   - Adds pmas_*.bat files in %TEMP% to Windows Defender exclusions
::     before execution,
::   - Extracts the main application to a randomly named temp file and runs it,
::   - Removes the exclusion and deletes the temp file when done.
::
:: =============================================================================

@echo off
title PMAS v12 by mephistooo2 ^| TNCTR.com
color 0a

set "_V_SIG=90accd73353ca043d8da60b83f29c67bf1f5fefc29d19b910eb000328e3120ae"
for /f %%i in ('powershell -NoProfile -Command "(Get-UICulture).Name"') do set "LANG=%%i"

setlocal enabledelayedexpansion

set "TEMP_SELF=%TEMP%\pv12_verify_%RANDOM%.tmp"
powershell -NoProfile -Command "$bytes=[IO.File]::ReadAllBytes('%~f0');$i=0;$n=0;while($i -lt $bytes.Length){if($i+1 -lt $bytes.Length -and $bytes[$i] -eq 13 -and $bytes[$i+1] -eq 10){$n++;if($n -eq 106){$i+=2;break};$i+=2}elseif($bytes[$i] -eq 10){$n++;if($n -eq 106){$i++;break};$i++}else{$i++}};[IO.File]::WriteAllBytes('%TEMP_SELF%',$bytes[$i..($bytes.Length-1)])"

for /f "delims=" %%H in ('certutil -hashfile "%TEMP_SELF%" SHA256 2^>nul ^| findstr /v "hash" ^| findstr /r /v "^$"') do (
    set "_CALC_HASH=%%H"
)

set "_CALC_HASH=!_CALC_HASH: =!"
echo !_CALC_HASH!| clip
del "%TEMP_SELF%" 2>nul

if /i not "!_CALC_HASH!"=="%_V_SIG%" (
    if /i "%LANG%"=="tr-TR" (
        mode con cols=95 lines=18
        echo.
        echo             PMAS v12 by mephistooo2 ^| TNCTR.com
        echo.
        echo             https://github.com/abdullah-erturk
        echo.
		echo             HATA: Komut Dosyası Bütünlük İhlali
		echo ==============================================================================================
		echo.
		echo Bu betik değiştirildi veya bozuldu.
		echo Güvenlik nedeniyle yürütme durduruldu.
		echo.
		echo Beklenen Hash : %_V_SIG%
		echo.
		echo ==============================================================================================
		echo.
		echo Çıkış için herhangi bir tuşa basın...
        pause >nul
        exit /b
    ) else (
        mode con cols=95 lines=18
        echo.
        echo             PMAS v12 by mephistooo2 ^| TNCTR.com
        echo.
        echo             https://github.com/abdullah-erturk
        echo.
        echo             ERROR: Script Integrity Violation
        echo ==============================================================================================
		echo.
        echo This script has been modified or corrupted.
        echo Execution stopped for security reasons.
        echo.
        echo Expected Hash : %_V_SIG%
        echo.
        echo ==============================================================================================
		echo.
        echo Press any key to exit...
        pause >nul
        exit /b
    )
)

